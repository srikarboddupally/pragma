# Copy to .env and fill in. Never commit .env. The redaction filter helps, but never log these.

# --- infrastructure ---
DATABASE_URL=postgresql+asyncpg://pragma:pragma@localhost:5432/pragma
REDIS_URL=redis://localhost:6379/0

# --- LLM / embeddings ---
OPENROUTER_API_KEY=sk-or-...          # LLM completion (default provider; OpenAI-compatible API)
LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free   # any OpenRouter model id; free-tier default
VOYAGE_API_KEY=                       # embeddings (default provider)
# OPENAI_API_KEY=sk-...               # only if EMBEDDING_PROVIDER=openai
EMBEDDING_PROVIDER=voyage             # voyage | openai | local

# --- actions / connectors ---
STRIPE_SECRET_KEY=sk_test_...
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_PRIVATE_KEY_PATH=          # path to the App's .pem private key file
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# --- security ---
PRAGMA_ENCRYPTION_KEY=                # Fernet key for credential encryption at rest
